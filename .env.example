# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit it.

# ── PostgreSQL (arcbox or your own server) ────────────────────────────────────
# Regular app account — CRUD operations only (no DDL privileges).
MAESTRO_DATABASE_URL=postgresql://maestro_user:password@localhost:5432/maestro_db

# Admin account — used ONLY by migration scripts (runner.py / migrate.bat).
# Must have full DDL privileges (CREATE/DROP TABLE, GRANT, etc.).
MAESTRO_ADMIN_DATABASE_URL=postgresql://maestro_admin:password@localhost:5432/maestro_db

# Test database — same server, separate DB.
# Migration runner applies to test first, then prod (see migrate.bat).
# Tests set MAESTRO_TEST=1 to switch to these URLs automatically.
MAESTRO_TEST_DATABASE_URL=postgresql://maestro_test:password@localhost:5432/maestro_test_db
MAESTRO_TEST_ADMIN_DATABASE_URL=postgresql://maestro_admin:password@localhost:5432/maestro_test_db

# ── Docker ────────────────────────────────────────────────────────────────────
# Remote Docker daemon (omit or leave blank to use the local Docker socket).
# On this project arcbox hosts the Docker daemon; the math sandbox image
# (sympy-lean4-sandbox:latest) is pre-built and resident there.
# DOCKER_HOST=ssh://user@arcbox

# ── Search API keys ───────────────────────────────────────────────────────────
# Set [search] provider in maestro.ini to "tavily" or "brave" to activate.
TAVILY_API_KEY=
BRAVE_API_KEY=
