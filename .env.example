# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit it.

# Database Configuration
# Set to true to use PostgreSQL, false to use SQLite (default)
MAESTRO_USE_POSTGRES=false

# Database URLs (PostgreSQL) - Required only if MAESTRO_USE_POSTGRES=true
# Regular user account (CRUD operations)
# MAESTRO_DATABASE_URL=postgresql://maestro_user:password@localhost:5432/maestro_db
# Admin account (Migrations and schema changes)
# MAESTRO_ADMIN_DATABASE_URL=postgresql://maestro_admin:password@localhost:5432/maestro_db

# Tavily Search API key (used when [search] provider = tavily)
TAVILY_API_KEY=

# Brave Search API key (used when [search] provider = brave)
BRAVE_API_KEY=
